quired":false},{"key":"website","label":"웹사이트","type":"text","required":false},{"key":"note","label":"비고","type":"text","required":false}],"nextCompanyId":8,"etcData":[],"etcColumns":[{"key":"vendor","label":"업체","type":"tag-vendor","required":true},{"key":"item","label":"항목","type":"text","required":false},{"key":"value","label":"내용","type":"text","required":false},{"key":"note","label":"비고","type":"text","required":false}],"nextEtcId":1,"acctData":[],"acctColumns":[{"key":"cont","label":"Cont.","type":"mono","required":true},{"key":"code","label":"품목코드","type":"text","required":false},{"key":"name","label":"품목명","type":"text","required":false},{"key":"unit","label":"단위","type":"text","required":false},{"key":"note","label":"비고","type":"text","required":false}],"nextAcctId":1,"erpsysData":[],"erpsysColumns":[{"key":"cont","label":"Cont.","type":"mono","required":true},{"key":"itemNo","label":"자재번호","type":"text","required":false},{"key":"name","label":"자재명","type":"text","required":false},{"key":"plant","label":"플랜트","type":"text","required":false},{"key":"note","label":"비고","type":"text","required":false}],"nextErpsysId":1,"orderData":[],"orderColumns":[{"key":"date","label":"발주일","required":true},{"key":"product","label":"제품","required":false},{"key":"controller","label":"컨트롤러","required":false},{"key":"qty","label":"수량(K)","required":false},{"key":"amount","label":"금액","required":false},{"key":"status","label":"상태","required":false},{"key":"note","label":"비고","required":false}],"nextOrderId":1,"meetingData":{},"nextMeetingId":1,"mailTemplates":[{"id":1,"name":"컨트롤러 출하","subject":"[컨트롤러 출고] {날짜} {외주사} 출고 컨트롤러 정보 공유의 건","body":"안녕하세요, 전략소싱 남서현입니다. \n\n{날짜} ({요일}) {외주사} 향 출고되는 Controller 수량 및 Mapfile 공유드립니다. \n\n총 {종류}종류, {CT}C/T이며, 아래 내용 확인 후 문의사항 있으시면 회신 부탁드립니다. \n\n세부사항은 첨부파일 참고 부탁드립니다."}],"nextMailId":2,"acctGuides":[{"id":"선급","name":"선급","type":"steps","steps":[{"no":"1","text":"입력"},{"no":"2","text":"미결전표"},{"no":"3","text":"미결영역 → F2 → 전략마케팅실"},{"no":"4","text":"추가 → 전표일자: AWB 좌측 상단 날짜 참고 (중국 건은 CI 날짜)"},{"no":"5","text":"코드 01 → F2 → 원재료(1205)"},{"no":"6","text":"적요: SSD/SIP/UDP CONTROLLER (대문자)"},{"no":"7","text":"원재료 품목, 단가, 매입처, 입고수량 → 인보이스 참고"},{"no":"8","text":"No 01줄 차변 더블클릭하고 환율 검색해서 한화로 바꾸기\n인보이스 상 달러 금액 × 일별 매매기준환율\n(중국→한국 건: AWB 날짜 기준 환율)\n(중국→중국 건: 인보이스 날짜 기준 환율)"},{"no":"9","text":"코드 02 → F2 → 외화선급금(1118)"},{"no":"10","text":"적요: SSD/SIP/UDP CONTROLLER (대문자)"},{"no":"11","text":"외화선급금 하단 환율 → 이동평균환율 (고현우 Pro 확인)"},{"no":"12","text":"외화금액: CI 상 금액 입력"},{"no":"13","text":"No2 대변 더블클릭"},{"no":"14","text":"코드 03, 두 금액 차이 확인 → F2 → 외환차손(5607) / 외환차익(4205)"},{"no":"15","text":"적요: SSD/SIP/UDP CONTROLLER (대문자)"},{"no":"16","text":"구분: 채권채무"},{"no":"17","text":"차변, 대변 금액 차이 확인 후 차손이면 No3 차변, 차익이면 No3 대변에 적기"},{"no":"18","text":"차변, 대변 금액 최종 확인"},{"no":"19","text":"저장"},{"no":"20","text":"인쇄"}]},{"id":"후급","name":"후급","type":"steps","steps":[{"no":"1","text":"입력"},{"no":"2","text":"미결전표"},{"no":"3","text":"미결영역 → F2 → 전략마케팅실"},{"no":"4","text":"추가 → 전표일자: AWB 좌측 상단 날짜 참고"},{"no":"5","text":"코드 01 → F2 → 원재료(1205)"},{"no":"6","text":"적요: SSD/SIP/UDP CONTROLLER (대문자)"},{"no":"7","text":"원재료 품목, 단가, 매입처, 입고수량 → 인보이스 참고"},{"no":"8","text":"No 01줄 차변 더블클릭하고 환율 검색해서 한화로 바꾸기\n인보이스 상 달러 금액 × 인보이스 상 날짜 일별 매매기준환율"},{"no":"9","text":"코드 02 → F2 → 2103(외상매입금)"},{"no":"10","text":"적요: SSD/SIP/UDP CONTROLLER (대문자)"},{"no":"11","text":"환율: 인보이스 상 날짜 일별 매매기준환율"},{"no":"12","text":"결제일: 물건 수령 후 익월 27일 입력"},{"no":"13","text":"외화금액: 인보이스 상 달러 금액 입력"},{"no":"14","text":"대변 더블클릭"},{"no":"15","text":"차변, 대변 같은지 확인. 다르면 반올림한 것 중 차이 많이 나는 순으로 반올림 적용 (품목이 많은 경우)\n차변은 수정할 수 없음"},{"no":"16","text":"저장"},{"no":"17","text":"인쇄"}]},{"id":"aio","name":"AIO 건","type":"steps","steps":[{"no":"1","text":"전표 날짜 = 세금계산서 날짜 = P/L 날짜 = 인보이스 날짜"},{"no":"2","text":"코드 02: 1123(부가선급금)"},{"no":"3","text":"증빙구분: 11 세금계산서"},{"no":"4","text":"사업장: 00 본사"},{"no":"5","text":"코드 03: 2102(외상매입금)"},{"no":"6","text":"결제일: 익월 27일"},{"no":"7","text":"환율: 인보이스 날짜 해당 환율"},{"no":"8","text":"외화금액: 인보이스 금액 × 1.1"},{"no":"9","text":"코드 03 대변 = 세금계산서 상 총 금액 → 수동으로 수정"},{"no":"10","text":"검산방법: 환율×외화금액 < 대변 < 환율×(외화금액+0.01)"},{"no":"11","text":"코드 01 차변 = 세금계산서 공급가액"},{"no":"12","text":"코드 02 차변 = 세금계산서 세액"}]},{"id":"공통","name":"공통 참고","type":"note","note":"환율 참고 — 서울외국환중개 사이트 (소수점 첫째자리에서 반올림)\nhttp://www.smbs.biz/index.jsp → 하단 \"기간별 매매기준율\" 클릭\n\n결제일 — 매달 27일 (후불 결제)\n후급 건 — 외환차손 / 외환차익 발생하지 않음\n한화 금액 — 무조건 반올림 적용"}],"erpGuides":[{"id":"order","name":"발주등록(통합)(S)","type":"steps","steps":[{"no":"1","text":"흰색칸 P/O No: 회사명 + 날짜 6자리(AWB 날짜) + A/B\n회사명 — SM: Silicon Motion, MA: Maxio, FC: FirstChip, AI: AIO, AS: Asolid"},{"no":"2","text":"발주형태: 외자발주(직수입)(PO)"},{"no":"3","text":"공급처 → F2 → 선택 (통화는 자동 표시) — 문제 시 재경팀 확인"},{"no":"4","text":"발주일: AWB 참고"},{"no":"5","text":"예상납기일: 실제 라모스 도착 날짜"},{"no":"6","text":"구매그룹 → F2 → 구매3그룹(P030)"},{"no":"7","text":"OFFER 작성일: AWB 참고"},{"no":"8","text":"가격조건 → F2 → 보통은 EXW이나 CI 참고 필요"},{"no":"9","text":"운송방법 → F2 → 항공편(AIR)\n※ AIO는 차량편(CAR), 가격조건 EXW\n※ 중국→중국 건도 항공편 (ERP 등록 완료 후 해당 창고로 재고이동등록 필요)"},{"no":"10","text":"행 추가 → 1 → OK"},{"no":"11","text":"공장 → 우측 네모 클릭 → 1공장(RF01)"},{"no":"12","text":"품목 → 우측 네모 클릭 → 검색"},{"no":"13","text":"발주수량, 단가: CI 참고"},{"no":"14","text":"HS code → 우측 네모 클릭 → Controller"},{"no":"15","text":"창고: RMSK"},{"no":"16","text":"저장 → 확정처리"}],"note":"AIO 건 — 통화 USD · 가격조건 EXW · B/L 금액은 세금계산서 금액(세전)으로 입력\n발주등록(통합)(S) 맨 위 상단에서 P/O No를 통해 이전 기록 조회 가능"},{"id":"bl","name":"B/L 등록(통합)","type":"steps","steps":[{"no":"1","text":"조회"},{"no":"2","text":"하단 □ 체크"},{"no":"3","text":"총중량 / 용적량 1"},{"no":"4","text":"선적일, B/L 접수일: AWB 참고"},{"no":"5","text":"수입B/L 정보 클릭"},{"no":"6","text":"B/L No: AWB 바코드 옆 10자리\n(중국→중국 건은 CI 뒤 내용 입력: SEORD~)"},{"no":"7","text":"하단 체크한 줄 B/L금액, B/L금액(자국) 2개 한번 더 확인"},{"no":"8","text":"저장"}],"note":"B/L 상세 조회에서 이전 기록 조회 가능\nAIO 건 — B/L No: P/L 8번 인보이스 num) 전체 예: AIO-AIO20260000-01 · 선적일/B/L 접수일은 인보이스 참고"},{"id":"customs","name":"통관등록(통합)","type":"steps","steps":[{"no":"1","text":"조회"},{"no":"2","text":"하단 □ 체크"},{"no":"3","text":"순중량 1"},{"no":"4","text":"수입신고(1) 클릭"},{"no":"5","text":"신고번호: PO No"},{"no":"6","text":"면허번호: PO No"},{"no":"7","text":"신고일: AWB 참고"},{"no":"8","text":"신고요청일: AWB 참고"},{"no":"9","text":"중량단위: KG"},{"no":"10","text":"도착항: 라모스"},{"no":"11","text":"저장"}]},{"id":"stock","name":"재고현황조회(S)","type":"steps","steps":[{"no":"1","text":"공장: 1공장, 창고: RMSK"},{"no":"2","text":"조회"}]},{"id":"purchase1","name":"구매입고등록(Multi)(S)","type":"steps","steps":[{"no":"1","text":"조회"},{"no":"2","text":"하단 □ 체크"},{"no":"3","text":"입출고일: 실제 자사 입고일"},{"no":"4","text":"구매그룹 → F2 → 구매3그룹(P030)"},{"no":"5","text":"저장"}]},{"id":"customslog","name":"통관관리대장출력","type":"steps","steps":[{"no":"1","text":"거래처 → F2 → 설정"},{"no":"2","text":"통관기간 설정"},{"no":"3","text":"인쇄"}]},{"id":"stockmove","name":"재고이동등록","type":"steps","steps":[{"no":"1","text":"공장 → 1공장(RF01)"},{"no":"2","text":"이동일 설정"},{"no":"3","text":"수불유형 → 우측 네모 클릭 → T01 창고간이동(양품양품)"},{"no":"4","text":"창고 → RMSK 창고(From 창고)"},{"no":"5","text":"재고이동내역 탭 클릭"},{"no":"6","text":"행 추가 (행 갯수 = 이동 품목 갯수)"},{"no":"7","text":"이동창고 → 우측 네모 클릭 → 외주사 창고(To 창고)"},{"no":"8","text":"품목 우측 □ 체크"},{"no":"9","text":"이동 수량 기입"},{"no":"10","text":"저장"}],"note":"이동일과 회계전표일은 무조건 동일하게 설정\n중국→중국 건은 선 RMSK 창고 입고 후 해당 창고로 이동"}]}